# Copy this file to .env and fill in real values as you provision each
# AWS resource. Anything left blank keeps the app in MOCK_MODE for that
# piece - see config.py.

AWS_REGION=us-east-1

# --- Knowledge Bases (Bedrock) ---
# Rules KB: created from kb_seed/rules_seed.csv (see kb_seed/README.md)
RULES_KB_ID=
# Metrics/Schema KB: connected to your Aurora/Redshift schema (NL2SQL) - not seeded from a file, set up via AWS console/CLI
METRICS_SCHEMA_KB_ID=
# Historical/Insights KB: not used yet (Data Agent only calls Rules KB + Metrics/Schema KB so far)
HISTORICAL_INSIGHTS_KB_ID=

# --- Redshift (Data API) ---
# Serverless: set REDSHIFT_WORKGROUP. Provisioned cluster: set REDSHIFT_CLUSTER_ID instead.
REDSHIFT_WORKGROUP=
REDSHIFT_CLUSTER_ID=
REDSHIFT_DATABASE=dev
REDSHIFT_SECRET_ARN=

# --- Mode, per service ---
# Flip only the ones you've actually provisioned. E.g. if only Rules KB
# is real so far, set RULES_KB_MOCK=false and leave the other two as
# true - Data Agent's downstream calls stay mocked until they're real too.
MOCK_MODE=true
RULES_KB_MOCK=true
METRICS_SCHEMA_KB_MOCK=true
REDSHIFT_MOCK=true
